{
  "name": "bevisa-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "generate:assets": "node scripts/generate-assets.mjs",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:content": "node scripts/content-lint.mjs",
    "test:sizes": "node scripts/check-component-sizes.mjs",
    "test:bundle": "node scripts/check-bundle.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "build": "npm run generate:assets && tsc -b && vite build && npm run test:content && npm run test:bundle",
    "check": "npm run typecheck && npm run lint && npm run test && npm run test:sizes && npm run audit:prod && npm run build",
    "preview": "vite preview --host 127.0.0.1",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium firefox webkit",
    "lighthouse": "node scripts/run-lighthouse.mjs"
  },
  "dependencies": {
    "@fontsource/familjen-grotesk": "5.2.8",
    "@fontsource/instrument-sans": "5.2.8",
    "@fontsource/spline-sans-mono": "5.2.8",
    "@react-three/drei": "9.120.8",
    "@react-three/fiber": "8.18.0",
    "framer-motion": "11.18.2",
    "gsap": "3.12.7",
    "lenis": "1.3.25",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "three": "0.170.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@eslint/js": "9.39.1",
    "@playwright/test": "1.56.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.1",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/three": "0.170.0",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "10.4.22",
    "chrome-launcher": "1.2.0",
    "eslint": "9.39.1",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "jsdom": "27.2.0",
    "lighthouse": "12.8.2",
    "postcss": "8.5.6",
    "sharp": "0.34.5",
    "tailwindcss": "3.4.19",
    "typescript": "5.7.3",
    "typescript-eslint": "8.48.1",
    "vite": "5.4.21",
    "vitest": "2.1.9"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
